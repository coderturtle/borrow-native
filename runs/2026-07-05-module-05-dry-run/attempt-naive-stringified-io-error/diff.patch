+        "desktop" => Ok(NotifierKind::Desktop),
+        "bell" => Ok(NotifierKind::TerminalBell),
+        "stdout" => Ok(NotifierKind::Stdout),
+        other => Err(ConfigError::UnknownNotifier(other.to_string())),
+    }
+}
