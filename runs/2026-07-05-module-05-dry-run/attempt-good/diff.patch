+    for line in input.lines() {
+        let line = line.trim();
+        if line.is_empty() {
+            continue;
+        }
+        let Some((key, value)) = line.split_once('=') else {
+            continue;
+        };
+        match key {
+            "checkpoint_interval_secs" => interval_raw = Some(value),
+            "notifier" => notifier_raw = Some(value),
